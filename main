// obstacle/feature types
// 0=spike  1=ball  2=platform(solid block)  3=orb(yellow)  4=gravity_portal  5=normal_portal
struct ObsDef { float x; int type; int w,h; float y_off; };
// y_off: for platforms = height above ground (0=on ground), for portals = screen y

// Full handcrafted level — ~14000px long. its manually made bc the parser thing didnt work...
// Platform: w=width in pixels, h=height in pixels, y_off=bottom of platform above GROUND_Y
// Orb:      y_off = height above ground
// Portal:   y_off = screen y of portal center
